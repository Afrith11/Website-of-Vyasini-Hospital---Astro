---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Calendar, User, ChevronRight } from '@lucide/astro';

const posts = await getCollection('blog');
// Sort posts by date (newest first)
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = [
  "All Articles",
  "General Health",
  "Women Health",
  "Child Health",
  "Diabetes Care",
  "Emergency Care"
];
---

<Layout 
  title="Medical Blog - VYASINI MULTI SPECIALTY HOSPITAL"
  description="Read articles written by the doctors at Vyasini Hospital (வியாசினி சிறப்பு மருத்துவமனை) on prenatal care, child health, diabetes, and first aid."
>
  
  <!-- Header Page Banner -->
  <section class="relative bg-gray-950 text-white py-16 sm:py-20 lg:py-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-gray-950 to-transparent z-10 opacity-80"></div>
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?auto=format&fit=crop&w=1200&q=80')] bg-cover bg-center opacity-25 mix-blend-overlay"></div>
    <div class="max-w-layout mx-auto px-4 sm:px-6 lg:px-8 relative z-20" data-aos="fade-up">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold font-heading">
        Health & Wellness Blog
      </h1>
      <p class="text-gray-300 mt-3 max-w-xl text-sm sm:text-base font-light">
        Expert articles, medical tips, and local health guidelines written by our specialists to guide your family's health journey.
      </p>
    </div>
  </section>

  <!-- Blog Content -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-layout mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Categories Row (Static layout for listing) -->
      <div 
        class="flex flex-wrap gap-2 justify-center mb-12"
        data-aos="fade-up"
      >
        {categories.map((cat, idx) => (
          <button
            class={`blog-cat-btn px-4 py-2.5 rounded-xl text-xs sm:text-sm font-semibold border transition-all duration-300 ${
              idx === 0
                ? "bg-medical-blue border-medical-blue text-white shadow-md shadow-medical-blue/10"
                : "bg-white border-gray-100 text-medical-slate hover:bg-gray-100 hover:text-medical-blue"
            }`}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Blog Grid -->
      <div 
        id="blog-posts-grid"
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        {sortedPosts.map(post => {
          const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          });
          
          return (
            <article 
              class="blog-post-card bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden flex flex-col justify-between group hover:shadow-md hover:border-medical-blue/30 transition-all duration-300"
              data-category={post.data.category}
            >
              <!-- Thumbnail Frame -->
              <div class="relative overflow-hidden h-52 sm:h-56 bg-gray-100 shrink-0">
                <div class="absolute inset-0 bg-gray-200 animate-pulse"></div>
                <!-- Fallback unsplash image in case local ones aren't available -->
                <img 
                  src={`https://images.unsplash.com/photo-1505751172876-fa1923c5c528?auto=format&fit=crop&w=600&q=80`} 
                  alt={post.data.title} 
                  class="w-full h-full object-cover relative z-10 group-hover:scale-103 transition-transform duration-500"
                  loading="lazy"
                />
                <div class="absolute top-4 left-4 z-20 bg-white/95 backdrop-blur px-3 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-wider text-medical-blue border border-gray-100 shadow-sm">
                  {post.data.category}
                </div>
              </div>

              <!-- Article Details -->
              <div class="p-6 sm:p-8 flex-grow flex flex-col justify-between">
                <div>
                  <!-- Meta details -->
                  <div class="flex items-center gap-4 text-xs text-medical-slate mb-4">
                    <div class="flex items-center gap-1.5">
                      <Calendar class="w-3.5 h-3.5" />
                      <span>{formattedDate}</span>
                    </div>
                    <div class="flex items-center gap-1.5">
                      <User class="w-3.5 h-3.5" />
                      <span>{post.data.author}</span>
                    </div>
                  </div>

                  <h2 class="text-lg font-bold text-medical-dark group-hover:text-medical-blue transition-colors mb-3 leading-tight">
                    {post.data.title}
                  </h2>
                  <p class="text-xs sm:text-sm text-medical-slate leading-relaxed mb-6 line-clamp-3">
                    {post.data.description}
                  </p>
                </div>

                <!-- CTA Link -->
                <div>
                  <a
                    href={`/blog/${post.slug}`}
                    class="flex items-center gap-1.5 text-xs sm:text-sm font-bold text-medical-blue hover:text-blue-700 transition-colors"
                  >
                    <span>Read Full Article</span>
                    <ChevronRight class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>

    </div>
  </section>

</Layout>

<script>
  // Simple client-side category filtering for blog cards
  const catBtns = document.querySelectorAll('.blog-cat-btn');
  const postCards = document.querySelectorAll('.blog-post-card');

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Toggle active states of buttons
      catBtns.forEach(b => {
        b.classList.remove('bg-medical-blue', 'border-medical-blue', 'text-white', 'shadow-md', 'shadow-medical-blue/10');
        b.classList.add('bg-white', 'border-gray-100', 'text-medical-slate');
      });
      btn.classList.add('bg-medical-blue', 'border-medical-blue', 'text-white', 'shadow-md', 'shadow-medical-blue/10');
      btn.classList.remove('bg-white', 'border-gray-100', 'text-medical-slate');

      // Filter grid
      const filterValue = btn.getAttribute('data-category');
      
      postCards.forEach(card => {
        const cardCategory = card.getAttribute('data-category');
        
        if (filterValue === 'All Articles' || cardCategory === filterValue) {
          (card as HTMLElement).style.display = 'flex';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
