---
import Layout from '../layouts/Layout.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import { 
  Phone, 
  Calendar, 
  ChevronRight, 
  Star, 
  Award, 
  ShieldCheck, 
  Heart, 
  Clock, 
  Users, 
  Stethoscope, 
  Activity, 
  Baby, 
  Smile, 
  Thermometer, 
  Sparkles 
} from '@lucide/astro';

const stats = [
  { value: "4.3 ★", label: "Google Rating", icon: Star, color: "text-yellow-500 bg-yellow-50" },
  { value: "21+", label: "Verified Reviews", icon: Users, color: "text-medical-teal bg-teal-50" },
  { value: "24/7", label: "Emergency Support", icon: Clock, color: "text-red-500 bg-red-50" },
  { value: "1000+", label: "Patients Served", icon: ShieldCheck, color: "text-medical-blue bg-blue-50" }
];

const specialities = [
  {
    id: "general-medicine",
    title: "General Medicine",
    icon: Stethoscope,
    description: "Expert diagnosis and primary care for common ailments, chronic conditions, and general health checkups.",
    image: "/images/specialities/general-medicine.jpg"
  },
  {
    id: "general-surgery",
    title: "General Surgery",
    icon: Activity,
    description: "Modern surgical procedures managed by highly skilled surgeons in fully equipped operating theaters.",
    image: "/images/specialities/general-surgery.jpg"
  },
  {
    id: "obstetrics-gynaecology",
    title: "Obstetrics & Gynaecology",
    icon: Baby,
    description: "Comprehensive care for women at all stages of life, specializing in prenatal care, deliveries, and post-natal care.",
    image: "/images/specialities/gynaecology.jpg"
  },
  {
    id: "paediatrics",
    title: "Paediatrics",
    icon: Smile,
    description: "Compassionate healthcare, vaccinations, and growth monitoring for infants, toddlers, and young children.",
    image: "/images/specialities/paediatrics.jpg"
  },
  {
    id: "orthopaedics",
    title: "Orthopaedics",
    icon: Award,
    description: "Specialized treatment for bone, joint, and ligament conditions, fracture management, and physical rehabilitation.",
    image: "/images/specialities/orthopaedics.jpg"
  },
  {
    id: "diabetes-care",
    title: "Diabetes Care",
    icon: Thermometer,
    description: "Personalized management plans, lifestyle counseling, and blood sugar control for diabetic and pre-diabetic patients.",
    image: "/images/specialities/diabetes-care.jpg"
  },
  {
    id: "emergency-care",
    title: "Emergency Care",
    icon: Clock,
    description: "24/7 trauma response team, fully stocked emergency beds, and ambulance facilities for critical health crises.",
    image: "/images/specialities/emergency-care.jpg"
  },
  {
    id: "family-healthcare",
    title: "Family Healthcare",
    icon: Heart,
    description: "Preventative healthcare plans, routine physicals, and family wellness consultations for all generations.",
    image: "/images/specialities/family-health.jpg"
  }
];

const whyChooseUs = [
  {
    title: "Experienced Doctors",
    description: "Consult with highly qualified, compassionate physicians and surgeons who put your health first.",
    icon: Stethoscope
  },
  {
    title: "Affordable Treatment",
    description: "Transparent pricing and affordable consultation fees, making premium care accessible to everyone.",
    icon: ShieldCheck
  },
  {
    title: "24/7 Emergency Care",
    description: "Critical trauma response, 24-hour pharmacy, diagnostics, and on-call specialist consultations.",
    icon: Clock
  },
  {
    title: "Patient-Centered Service",
    description: "Dedicated nursing staff providing attentive care in a clean, hygienic, and comforting environment.",
    icon: Users
  },
  {
    title: "Modern Equipment",
    description: "Equipped with state-of-the-art diagnostic machinery, laboratory testing, and advanced operation tools.",
    icon: Activity
  },
  {
    title: "Quality Healthcare",
    description: "Adhering to high medical standards to deliver safe, effective, and evidence-based treatments.",
    icon: Sparkles
  }
];
---

<Layout title="VYASINI MULTI SPECIALTY HOSPITAL - Bodinayakanur, Sillamarathupatti">
  
  <!-- Hero Section -->
  <section class="relative bg-gray-950 text-white overflow-hidden py-24 sm:py-32 lg:py-40">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-r from-gray-950 via-gray-900/90 to-transparent z-10"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-transparent to-transparent z-10"></div>
      <div class="w-full h-full bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-blue-900/20 via-gray-950 to-gray-950 absolute z-0"></div>
      <!-- Fallback pattern or dynamic image placeholder -->
      <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1587351021759-3e566b6af7cc?auto=format&fit=crop&w=1600&q=80')] bg-cover bg-center opacity-30 mix-blend-overlay"></div>
    </div>

    <div class="max-w-layout mx-auto px-4 sm:px-6 lg:px-8 relative z-20">
      <div class="max-w-3xl" data-aos="fade-right">
        <!-- Badge -->
        <div class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full bg-medical-blue/20 border border-medical-blue/30 text-medical-accent text-xs font-bold uppercase tracking-wider mb-6">
          <span class="w-2 h-2 rounded-full bg-medical-teal animate-ping"></span>
          <span>Vyasini Multi Specialty Hospital</span>
        </div>
        
        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-tight font-heading">
          Trusted Healthcare <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-medical-blue to-medical-teal">for Every Generation</span>
        </h1>
        
        <!-- Subheadline -->
        <p class="mt-6 text-base sm:text-lg lg:text-xl text-gray-300 leading-relaxed font-sans font-light max-w-2xl">
          Providing compassionate, affordable, and quality healthcare services with experienced doctors and modern medical facilities in Bodinayakanur and Sillamarathupatti.
        </p>
        
        <!-- CTA Buttons -->
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="/appointment"
            class="flex items-center gap-2 px-8 py-4 bg-medical-blue hover:bg-blue-600 text-white font-bold rounded-xl text-base transition-all duration-300 shadow-lg shadow-medical-blue/25 hover:shadow-xl hover:shadow-medical-blue/35 hover:-translate-y-0.5"
          >
            <Calendar class="w-5 h-5" />
            <span>Book Appointment</span>
          </a>
          <a
            href="tel:+919944061805"
            class="flex items-center gap-2 px-8 py-4 bg-white/10 hover:bg-white/15 text-white font-bold rounded-xl text-base border border-white/20 transition-all duration-300 backdrop-blur-sm hover:-translate-y-0.5"
          >
            <Phone class="w-5 h-5 text-medical-teal" />
            <span>Call Hospital</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Statistics Section -->
  <section class="relative z-30 -mt-10 max-w-layout mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-3xl shadow-xl border border-gray-100 p-6 sm:p-10 grid grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8 divide-y lg:divide-y-0 lg:divide-x divide-gray-100">
      {stats.map((stat, index) => (
        <div 
          class={`flex items-center gap-4 ${index > 1 ? 'pt-6 lg:pt-0' : ''} ${index % 2 !== 0 ? 'ps-4 lg:ps-8' : ''} ${index > 0 && index % 2 === 0 ? 'pt-6 lg:pt-0 lg:ps-8' : ''} ${index === 0 ? 'lg:ps-0' : ''}`}
          data-aos="fade-up"
          data-aos-delay={index * 50}
        >
          <div class={`w-12 h-12 rounded-2xl flex items-center justify-center shrink-0 ${stat.color}`}>
            <stat.icon class="w-6 h-6" />
          </div>
          <div>
            <div class="text-2xl sm:text-3xl font-extrabold text-medical-dark font-heading leading-tight">{stat.value}</div>
            <div class="text-xs sm:text-sm font-semibold text-medical-slate tracking-wide uppercase mt-0.5">{stat.label}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Specialties Section -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-layout mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Section Header -->
      <div class="text-center mb-16" data-aos="fade-up">
        <span class="text-xs font-bold text-medical-teal tracking-widest uppercase bg-medical-teal/10 px-3 py-1 rounded-full">
          Medical Specialties
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold text-medical-dark mt-3">
          Our Specialities & Services
        </h2>
        <p class="text-medical-slate mt-2 max-w-xl mx-auto text-sm sm:text-base">
          Vyasini Hospital offers dedicated patient care across various general and specialist medical disciplines.
        </p>
      </div>

      <!-- Specialties Cards Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
        {specialities.map((spec, index) => (
          <div 
            class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-md hover:border-medical-blue/30 transition-all duration-300 flex flex-col justify-between group"
            data-aos="fade-up"
            data-aos-delay={index * 50}
          >
            <div class="p-6 sm:p-8">
              <div class="w-12 h-12 rounded-xl bg-medical-blue/10 text-medical-blue flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-medical-blue group-hover:text-white transition-all duration-300">
                <spec.icon class="w-6 h-6" />
              </div>
              <h3 class="text-lg sm:text-xl font-bold text-medical-dark group-hover:text-medical-blue transition-colors mb-3">
                {spec.title}
              </h3>
              <p class="text-sm text-medical-slate leading-relaxed">
                {spec.description}
              </p>
            </div>
            <div class="px-6 sm:px-8 pb-6 sm:pb-8 pt-0">
              <a 
                href={`/specialities#${spec.id}`}
                class="flex items-center gap-1.5 text-sm font-bold text-medical-blue hover:text-blue-700 transition-colors"
              >
                <span>Learn More</span>
                <ChevronRight class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
              </a>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="py-24 bg-white relative">
    <div class="max-w-layout mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Section Header -->
      <div class="text-center mb-16" data-aos="fade-up">
        <span class="text-xs font-bold text-medical-teal tracking-widest uppercase bg-medical-teal/10 px-3 py-1 rounded-full">
          Why Choose Us
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold text-medical-dark mt-3">
          Compassionate & Quality Care
        </h2>
        <p class="text-medical-slate mt-2 max-w-xl mx-auto text-sm sm:text-base">
          Our commitment is to offer reliable, affordable, and modern medical solutions for you and your family.
        </p>
      </div>

      <!-- Why Choose Us Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 sm:gap-10">
        {whyChooseUs.map((item, index) => (
          <div 
            class="flex gap-5 p-6 rounded-2xl hover:bg-medical-light border border-transparent hover:border-gray-100 transition-all duration-300"
            data-aos="fade-up"
            data-aos-delay={index * 50}
          >
            <div class="w-12 h-12 rounded-xl bg-medical-teal/10 text-medical-teal flex items-center justify-center shrink-0 shadow-sm shadow-medical-teal/5">
              <item.icon class="w-6 h-6" />
            </div>
            <div>
              <h3 class="text-base sm:text-lg font-bold text-medical-dark mb-2">{item.title}</h3>
              <p class="text-sm text-medical-slate leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- Patient Reviews Carousel Component -->
  <Testimonials />

  <!-- FAQ Section Component -->
  <FAQ />

  <!-- CTA Banner Section -->
  <section class="py-16 bg-gradient-to-r from-medical-blue to-medical-teal text-white">
    <div class="max-w-layout mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-8 text-center lg:text-left">
        <div>
          <h2 class="text-2xl sm:text-3xl font-extrabold leading-tight">
            Need Expert Medical Guidance?
          </h2>
          <p class="text-white/85 text-sm sm:text-base mt-2 max-w-xl">
            Book an appointment online, speak with our front desk, or send us a message on WhatsApp. We are here to serve you.
          </p>
        </div>
        <div class="flex flex-wrap items-center justify-center gap-4 shrink-0">
          <a
            href="/appointment"
            class="px-6 py-3.5 bg-white text-medical-blue font-bold rounded-xl text-sm hover:bg-gray-50 hover:-translate-y-0.5 active:translate-y-0 transition-all shadow-md"
          >
            Book Appointment Now
          </a>
          <a
            href="https://wa.me/919944061805"
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3.5 bg-green-500 text-white font-bold rounded-xl text-sm hover:bg-green-600 hover:-translate-y-0.5 active:translate-y-0 transition-all shadow-md flex items-center gap-2"
          >
            <span>Chat on WhatsApp</span>
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
