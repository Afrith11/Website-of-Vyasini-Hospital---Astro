---
import Layout from '../layouts/Layout.astro';
import { Stethoscope, Calendar, Mail, Award, Clock, ArrowRight } from '@lucide/astro';

const doctors = [
  {
    name: "Dr. Deepa, MBBS, DGO",
    specialization: "Obstetrics & Gynaecology",
    qualification: "MBBS, Diploma in Gynaecology & Obstetrics",
    experience: "10+ Years of Experience",
    timings: "Mon - Sat: 9:00 AM - 5:00 PM",
    image: "https://images.unsplash.com/photo-1594824813573-246434de83fb?auto=format&fit=crop&w=400&q=80",
    phone: "+919944061805"
  },
  {
    name: "Dr. Ashok, MBBS, MD (Paed)",
    specialization: "Paediatrics & Child Care",
    qualification: "MBBS, MD in Paediatrics",
    experience: "8+ Years of Experience",
    timings: "Mon - Sat: 10:00 AM - 6:00 PM",
    image: "https://images.unsplash.com/photo-1622253692010-333f2da6031d?auto=format&fit=crop&w=400&q=80",
    phone: "+919944061805"
  },
  {
    name: "Dr. Senthil, MBBS, MD",
    specialization: "General Physician & Diabetes Care",
    qualification: "MBBS, MD in General Medicine",
    experience: "12+ Years of Experience",
    timings: "Mon - Sun: 9:00 AM - 8:00 PM (Emergency)",
    image: "https://images.unsplash.com/photo-1537368910025-700350fe46c7?auto=format&fit=crop&w=400&q=80",
    phone: "+919944061805"
  }
];

const placeholders = [
  {
    role: "Orthopaedics Specialist",
    status: "Expanding Soon",
    desc: "We are onboarding an experienced Orthopaedic surgeon to serve Bodinayakanur patients locally."
  },
  {
    role: "General Surgeon Specialist",
    status: "Expanding Soon",
    desc: "A dedicated General & Laparoscopic surgeon will be joining our consulting desk shortly."
  }
];
---

<Layout 
  title="Our Doctors - VYASINI MULTI SPECIALTY HOSPITAL"
  description="Meet the experienced doctors and healthcare professionals at Vyasini Multi Specialty Hospital in Bodinayakanur and Sillamarathupatti."
>
  
  <!-- Header Page Banner -->
  <section class="relative bg-gray-950 text-white py-16 sm:py-20 lg:py-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-gray-950 to-transparent z-10 opacity-80"></div>
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1559839734-2b71ea197ec2?auto=format&fit=crop&w=1200&q=80')] bg-cover bg-center opacity-25 mix-blend-overlay"></div>
    <div class="max-w-layout mx-auto px-4 sm:px-6 lg:px-8 relative z-20" data-aos="fade-up">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold font-heading">
        Our Medical Team
      </h1>
      <p class="text-gray-300 mt-3 max-w-xl text-sm sm:text-base font-light">
        Consult with highly qualified, experienced, and caring medical professionals committed to your health.
      </p>
    </div>
  </section>

  <!-- Doctors Section -->
  <section class="py-20 bg-white">
    <div class="max-w-layout mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Section Intro -->
      <div class="text-center mb-16" data-aos="fade-up">
        <span class="text-xs font-bold text-medical-teal tracking-widest uppercase bg-medical-teal/10 px-3 py-1 rounded-full">
          Medical Specialists
        </span>
        <h2 class="text-3xl font-bold text-medical-dark mt-3 font-heading">
          Meet Our Experts
        </h2>
        <p class="text-medical-slate mt-2 max-w-xl mx-auto text-sm sm:text-base">
          Our panel consists of dedicated doctors providing general medicine, diabetic care, gynaecology, and paediatric treatments.
        </p>
      </div>

      <!-- Doctor Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
        {doctors.map((doc, index) => (
          <div 
            class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden flex flex-col group hover:shadow-md hover:border-medical-blue/30 transition-all duration-300"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <!-- Image Frame -->
            <div class="relative overflow-hidden h-72 sm:h-80 bg-gray-50 shrink-0">
              <img 
                src={doc.image} 
                alt={doc.name} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute top-4 right-4 bg-white/95 backdrop-blur px-3 py-1.5 rounded-full text-xs font-bold text-medical-blue border border-gray-100 shadow-sm">
                {doc.specialization}
              </div>
            </div>

            <!-- Doctor Bio -->
            <div class="p-6 sm:p-8 flex-grow flex flex-col justify-between">
              <div>
                <h3 class="text-lg sm:text-xl font-bold text-medical-dark group-hover:text-medical-blue transition-colors mb-2">
                  {doc.name}
                </h3>
                
                <div class="space-y-3 text-xs sm:text-sm text-medical-slate mb-6">
                  <div class="flex items-center gap-2">
                    <Award class="w-4 h-4 text-medical-teal shrink-0" />
                    <span>{doc.qualification}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <Stethoscope class="w-4 h-4 text-medical-teal shrink-0" />
                    <span>{doc.experience}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <Clock class="w-4 h-4 text-medical-teal shrink-0" />
                    <span>{doc.timings}</span>
                  </div>
                </div>
              </div>

              <!-- Button CTA -->
              <a
                href={`/appointment?doctor=${encodeURIComponent(doc.name)}`}
                class="w-full py-3 bg-medical-blue hover:bg-blue-600 text-white rounded-xl text-xs sm:text-sm font-bold transition-colors flex items-center justify-center gap-2 shadow-md shadow-medical-blue/20 hover:shadow-lg"
              >
                <Calendar class="w-4 h-4" />
                <span>Book Appointment</span>
              </a>
            </div>
          </div>
        ))}
      </div>

      <!-- Placeholder Support Section for Future Expansion -->
      <div class="border-t border-gray-100 pt-16">
        <div class="text-center mb-10" data-aos="fade-up">
          <h3 class="text-xl sm:text-2xl font-bold text-medical-dark">Expanding Our Medical Team</h3>
          <p class="text-medical-slate text-sm mt-2 max-w-lg mx-auto">
            We are consistently expanding our clinical departments to bring high-quality specialist treatments closer to Bodinayakanur and Sillamarathupatti.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {placeholders.map((p, index) => (
            <div 
              class="bg-gray-50 border border-dashed border-gray-200 p-8 rounded-3xl text-center flex flex-col justify-between h-full hover:border-medical-blue/30 transition-colors"
              data-aos="fade-up"
              data-aos-delay={index * 50}
            >
              <div>
                <span class="inline-block px-3 py-1 bg-medical-teal/10 text-medical-teal rounded-full text-xs font-bold uppercase tracking-wider mb-4">
                  {p.status}
                </span>
                <h4 class="font-bold text-lg text-medical-dark mb-2">{p.role}</h4>
                <p class="text-xs sm:text-sm text-medical-slate leading-relaxed">{p.desc}</p>
              </div>
              <div class="mt-6 text-xs text-medical-blue font-bold tracking-wide">
                Coming Soon
              </div>
            </div>
          ))}

          <!-- Join us Career Card -->
          <div 
            class="bg-gradient-to-br from-medical-blue/5 to-medical-teal/5 border border-medical-blue/10 p-8 rounded-3xl text-center flex flex-col justify-between h-full"
            data-aos="fade-up"
            data-aos-delay="150"
          >
            <div>
              <span class="inline-block px-3 py-1 bg-medical-blue/10 text-medical-blue rounded-full text-xs font-bold uppercase tracking-wider mb-4">
                Careers
              </span>
              <h4 class="font-bold text-lg text-medical-dark mb-2">Join Our Clinical Team</h4>
              <p class="text-xs sm:text-sm text-medical-slate leading-relaxed">
                Are you a qualified doctor, specialist, or nurse looking to serve patients in Sillamarathupatti, Bodinayakanur, and Theni? Let's talk.
              </p>
            </div>
            <div class="mt-6">
              <a 
                href="mailto:careers@vyasinihospital.com?subject=Medical%20Career%20Inquiry"
                class="inline-flex items-center gap-1.5 text-xs sm:text-sm font-bold text-medical-blue hover:text-blue-700 transition-colors"
              >
                <span>Email Your CV</span>
                <ArrowRight class="w-4 h-4" />
              </a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>
