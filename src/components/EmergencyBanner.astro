---
import { Phone, MapPin, Star } from '@lucide/astro';
---

<div class="bg-gradient-to-r from-medical-blue to-medical-teal text-white text-xs sm:text-sm py-2 px-4 shadow-sm z-50">
  <div class="max-w-layout mx-auto flex flex-col md:flex-row justify-between items-center gap-2 md:gap-4 font-medium">
    
    <!-- Left Section: Address & Rating -->
    <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-4">
      <div class="flex items-center gap-1">
        <MapPin class="w-3.5 h-3.5" />
        <span>Pulikuthi-Bodinayakanur Road, Sillamarathupatti</span>
      </div>
      <div class="hidden sm:flex items-center gap-1 bg-white/20 px-2 py-0.5 rounded-full">
        <Star class="w-3 h-3 fill-yellow-400 stroke-yellow-400" />
        <span>4.3 ★ Google Rating (21 Reviews)</span>
      </div>
    </div>
    
    <!-- Right Section: Emergency Call -->
    <div class="flex items-center gap-4">
      <a href="tel:+919944061805" class="flex items-center gap-1.5 hover:underline bg-red-600 hover:bg-red-700 px-3 py-1 rounded text-xs font-bold animate-pulse">
        <Phone class="w-3.5 h-3.5" />
        <span>EMERGENCY: +91 99440 61805</span>
      </a>
      <span class="hidden md:inline border-l border-white/30 h-4"></span>
      <span class="hidden md:inline text-white/90">24/7 Care & Support</span>
    </div>
    
  </div>
</div>
