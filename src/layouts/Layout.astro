---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingActions from '../components/FloatingActions.astro';
import EmergencyBanner from '../components/EmergencyBanner.astro';
import 'aos/dist/aos.css';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "VYASINI MULTI SPECIALTY HOSPITAL - Providing compassionate, affordable, and quality healthcare services with experienced doctors in Bodinayakanur, Sillamarathupatti.",
  keywords = "Best Hospital in Bodinayakanur, Multispeciality Hospital in Bodinayakanur, Hospital in Sillamarathupatti, Healthcare Services in Theni, Emergency Care Hospital, Affordable Hospital in Bodinayakanur, General Physician Bodinayakanur, Women Healthcare Hospital, Child Healthcare Hospital, Medical Services Near Me, Healthcare Centre Theni",
  ogImage = "/images/og-image.jpg",
  canonicalUrl = Astro.url.href
} = Astro.props;

// Generate breadcrumb list schema dynamically
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = [
  { name: 'Home', item: Astro.site || Astro.url.origin }
];
let currentPath = Astro.site ? Astro.site.origin : Astro.url.origin;
pathSegments.forEach((segment, index) => {
  currentPath += `/${segment}`;
  breadcrumbItems.push({
    name: segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' '),
    item: currentPath
  });
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": item.item
  }))
};

const medicalOrganizationSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "name": "VYASINI MULTI SPECIALTY HOSPITAL",
  "alternateName": "வியாசினி சிறப்பு மருத்துவமனை",
  "image": "https://vyasinihospital.com/images/hospital-building.jpg",
  "@id": "https://vyasinihospital.com/#hospital",
  "url": "https://vyasinihospital.com",
  "telephone": "+91 99440 61805",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Pulikuthi-Bodinayakanur Road, Sillamarathupatti",
    "addressLocality": "Bodinayakanur",
    "addressRegion": "Tamil Nadu",
    "postalCode": "625528",
    "addressCountry": "IN"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "9.9734",
    "longitude": "77.2917"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
      "Sunday"
    ],
    "opens": "00:00",
    "closes": "23:59"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.3",
    "reviewCount": "21"
  }
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Meta tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- JSON-LD Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(medicalOrganizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <body class="bg-white text-medical-dark font-sans min-h-screen flex flex-col antialiased">
    <EmergencyBanner />
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
    <FloatingActions />

    <!-- AOS Script initialization -->
    <script>
      import AOS from 'aos';
      AOS.init({
        duration: 800,
        easing: 'ease-out-cubic',
        once: true,
        offset: 80,
        delay: 50
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #0F6FFF;
    --color-secondary: #00B8A9;
  }
  
  body {
    font-family: 'Inter', sans-serif;
  }
  
  h1, h2, h3, h4, h5, h6 {
    font-family: 'Poppins', sans-serif;
  }

  .text-gradient {
    background: linear-gradient(135deg, #0F6FFF 0%, #00B8A9 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .bg-gradient-primary {
    background: linear-gradient(135deg, #0F6FFF 0%, #00B8A9 100%);
  }

  /* Glassmorphism utility */
  .glass-card {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  /* Hide scrollbar for Chrome, Safari and Opera */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .no-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>
